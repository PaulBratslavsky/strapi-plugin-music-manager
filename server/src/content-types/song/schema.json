{
  "kind": "collectionType",
  "collectionName": "music_manager_songs",
  "info": {
    "singularName": "song",
    "pluralName": "songs",
    "displayName": "Song",
    "description": "A music track with audio file and waveform data"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "artist": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::strapi-plugin-music-manager.artist",
      "inversedBy": "songs"
    },
    "audio": {
      "allowedTypes": ["audios"],
      "type": "media",
      "multiple": false
    },
    "peaks": {
      "type": "json"
    },
    "duration": {
      "type": "float"
    }
  }
}
