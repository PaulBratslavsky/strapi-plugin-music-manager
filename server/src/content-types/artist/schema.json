    },
    "bio": {
      "type": "text"
    },
    "image": {
      "allowedTypes": ["images"],
      "type": "media",
      "multiple": false
    },
    "songs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::strapi-plugin-music-manager.song",
      "mappedBy": "artist"
    }
  }
}
